{
  "name": "synthicide",
  "version": "3.0.0",
  "description": "Compiler for the Synthicide system",
  "scripts": {
    "createSymlinks": "node src/create-symlinks.mjs",
    "lint": "eslint .",
    "prebuild": "npm run packs:validate && npm run packs:build-yml",
    "build": "npx gulp build",
    "packs:validate": "node ./scripts/validate-pack-manifest.mjs",
    "packs:build-yml": "node ./scripts/yml-to-db.mjs",
    "packs:export-yml": "node ./scripts/db-to-yml.mjs",
    "packs:rebuild-yml": "npm run packs:build-yml && npm run packs:export-yml",
    "build:develop": "npm run build && rm -rf ~/Library/Application\\ Support/FoundryVTT/Data/systems/synthicide && ln -sfn \"$(pwd)/dist\" ~/Library/Application\\ Support/FoundryVTT/Data/systems/synthicide"
  },
  "type": "module",
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Marvin",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "eslint": "^10.0.0",
    "fs-extra": "^11.3.3",
    "globals": "^17.3.0",
    "js-yaml": "^4.1.1",
    "rollup": "^4.59.0",
    "rollup-plugin-import-css": "^4.2.0"
  },
  "dependencies": {
    "gulp": "^5.0.1"
  }
}
