{{! NPC Notes / Info Tab }}
<section
  class='tab info npcStats scrollable {{tab.cssClass}}'
  data-group='primary'
  data-tab='info'
>
  <div class="flexrow">
    <h4 class='npc-section-heading'>{{localize 'SYNTHICIDE.Actor.NPC.UI.NPCNotes'}}</h4>
  </div>
  <div class='npc-board'>
    <section class='npc-board-section npc-notes-section'>
      <div class='npc-notes-grid'>
        <div class='npc-note-field'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Actor.NPC.UI.UniquePower'}}</label>
          <input type='text' name='system.uniquePower' value='{{system.uniquePower}}'>
        </div>
        <div class='npc-note-field'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Actor.NPC.UI.BossPower'}}</label>
          <input type='text' name='system.bossPower' value='{{system.bossPower}}'>
        </div>
        <div class='npc-note-field'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Actor.NPC.UI.Loot'}}</label>
          <input type='text' name='system.loot' value='{{system.loot}}'>
        </div>
        <div class='npc-note-field npc-note-field-wide'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Actor.NPC.UI.Notes'}}</label>
          <input type='text' name='system.notes' value='{{system.notes}}'>
        </div>
      </div>
    </section>
  </div>
</section>
