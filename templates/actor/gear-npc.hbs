{{! NPC Gear Tab (merged inventory list) }}
<section class='tab gear scrollable {{tab.cssClass}}' data-group='primary' data-tab='gear'>
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>{{localize 'Name'}}</div>
      <div class='item-prop'>{{localize 'Type'}}</div>
      <div class='item-prop'>{{localize 'SYNTHICIDE.Item.Gear.FIELDS.quantity.label'}}</div>
      <div class='item-prop'>{{localize 'SYNTHICIDE.Item.Gear.FIELDS.price.label'}}(§)</div>
      <div class='item-controls'>
        {{#if @root.editable}}
          <a
            class='item-control item-create'
            data-tooltip='{{localize "DOCUMENT.Create" type='Item'}}'
            data-action='createDoc'
            data-document-class='Item'
            data-type='gear'
          >
            <i class='fas fa-plus'></i>
            {{localize 'DOCUMENT.New' type='item'}}
          </a>
        {{/if}}
      </div>
    </li>

    {{#each npcInventory as |item id|}}
      <li
        class='item flexrow draggable'
        data-item-id='{{item._id}}'
        data-document-class='Item'
      >
        <div class='item-name'>
          <div class='item-image'>
            <img src='{{item.img}}' data-tooltip='{{item.name}}' />
          </div>
          <div class='item-label'>{{item.name}}</div>
        </div>
        <div class='item-prop'>{{localize (concat 'TYPES.Item.' item.type)}}</div>
        <div class='item-prop'>{{#if item.system.quantity}}{{item.system.quantity}}{{else}}-{{/if}}</div>
        <div class='item-prop'>{{#if item.system.price}}{{item.system.price}}{{else}}-{{/if}}</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a
              class='item-control item-edit'
              data-tooltip='{{localize "DOCUMENT.Update" type='Item'}}'
              data-action='viewDoc'
            >
              <i class='fas fa-edit'></i>
            </a>
            <a
              class='item-control item-delete'
              data-tooltip='{{localize "DOCUMENT.Delete" type='Item'}}'
              data-action='deleteDoc'
            >
              <i class='fas fa-trash'></i>
            </a>
          {{/if}}
        </div>
      </li>
    {{/each}}
  </ol>
</section>
