{{log this}}
{{! Features Tab }}
<section
  class='tab features scrollable {{tab.cssClass}}'
  data-group='primary'
  data-tab='features'
>
  <section class='grid grid-3col'>
    <aside class='sidebar'>
      <div class="attributes-table">
        <div class="attributes-header">Attribute</div>
        <div class="attributes-header">Level Increase</div>
        <div class="attributes-header">Current</div>
        {{#each system.attributes as |attribute key|}}
          <div class="attribute-label">
            <span
              class="rollable"
              data-action="roll"
              data-roll="d10+@attributes.{{key}}.current"
              data-label="{{localize (lookup @root.config.attributes key)}}"
              tabindex="0"
              role="button"
            >
              {{localize (lookup @root.config.attributes key)}}
            </span>
          </div>
          <div class="attribute-input">
            <div class="attribute-stepper" data-attribute-key="{{key}}">
              <button type="button" class="attribute-step-btn" data-action="decreaseAttribute" data-attribute-key="{{key}}" aria-label="Decrease {{localize (lookup @root.config.attributes key)}}">-</button>
              <input type="number" name="system.attributes.{{key}}.increase" value="{{attribute.increase}}" class="attribute-score" data-dtype="Number" min="0" max="5" step="1">
              <button type="button" class="attribute-step-btn" data-action="increaseAttribute" data-attribute-key="{{key}}" aria-label="Increase {{localize (lookup @root.config.attributes key)}}">+</button>
            </div>
          </div>
          <div class="attribute-current">{{numberFormat attribute.current decimals=0 sign=true}}</div>
        {{/each}}
      </div>
    </aside>

    {{! For the main features list, span the right two columns }}
    <section class='main grid-span-2'>
      <ol class='items-list'>
        <li class='item flexrow items-header'>
          <div class='item-name'>{{localize 'Name'}}</div>
          <div class='item-controls'>
            {{#if @root.editable}}
              <a
                class='item-control item-create'
                data-tooltip='Create item'
                data-action='createDoc'
                data-document-class='Item'
                data-type='feature'
              >
                <i class='fas fa-plus'></i>
                {{localize 'DOCUMENT.New' type='feature'}}
              </a>
            {{/if}}
          </div>
        </li>
        {{#each features as |item id|}}
          <li
            class='item flexrow draggable'
            data-item-id='{{item._id}}'
            data-document-class='Item'
          >
            <div class='item-name'>
              <div class='item-image'>
                <a class='rollable' data-roll-type='item' data-action='roll'>
                  <img
                    src='{{item.img}}'
                    data-tooltip='{{item.name}}'
                    width='24'
                    height='24'
                  />
                </a>
              </div>
              <div>{{item.name}}</div>
            </div>
            <div class='item-controls'>
              <a
                class='item-control item-edit'
                data-tooltip='{{localize "DOCUMENT.Update" type='feature'}}'
                data-action='viewDoc'
              >
                <i class='fas fa-edit'></i>
              </a>
              {{#if @root.editable}}
                <a
                  class='item-control item-delete'
                  data-tooltip='{{localize "DOCUMENT.Delete" type='feature'}}'
                  data-action='deleteDoc'
                >
                  <i class='fas fa-trash'></i>
                </a>
              {{/if}}
            </div>
          </li>
        {{/each}}
      </ol>
    </section>
  </section>
</section>