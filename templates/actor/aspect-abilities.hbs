{{! Aspect tab mirrors bioclass-traits.hbs structure }}
<section
  class='tab aspect scrollable {{tab.cssClass}}'
  data-group='primary'
  data-tab='aspect'
>
  {{#if aspect}}
    <ol class='items-list'>
      <li class='item flexrow items-header' data-document-class="Item" data-item-id="{{aspect.id}}">
        <div class='item-name'>{{localize 'TYPES.Item.aspect'}}: {{aspect.name}}</div>
        <div class='item-controls'>
          <a class='item-control item-info' data-action='showInfo' data-tooltip='{{{aspect.system.description}}}'>
            <i class='fas fa-info-circle'></i>
          </a>
          {{#if @root.editable}}
            <a class='item-control' data-action='viewDoc' data-tooltip='{{localize "EDIT"}}'>
              <i class='fas fa-edit'></i>
            </a>
            <a class='item-control item-delete' data-action='deleteDoc' data-tooltip='{{localize "DOCUMENT.Delete" type='aspect'}}'>
              <i class='fas fa-trash'></i>
            </a>
          {{/if}}
        </div>
      </li>
    </ol>

    {{!-- Abilities section (rendered above traits) --}}
    <div class='section abilities'>
      <h4>{{localize "SYNTHICIDE.Actor.Aspect.Abilities"}}</h4>
      {{#if aspect.system.abilities.length}}
        <ol class='abilities-list'>
          {{#each aspect.system.abilities}}
            <li class='ability'>
              <span class='ability-name'>{{#if this.description}}{{this.description}}{{else}}{{this}}{{/if}}</span>
            </li>
          {{/each}}
        </ol>
      {{else}}
        <p>{{localize 'SYNTHICIDE.Actor.Aspect.NoAbilities'}}</p>
      {{/if}}
    </div>

    {{!-- Traits generated by aspect --}}
    <h4>{{localize "SYNTHICIDE.Actor.Aspect.Traits"}}</h4>
    {{#if aspectTraits.length}}
      <div class='grid grid-1col'>
        {{#each aspectTraits as |trait i|}}
          <fieldset class='resource' data-item-id='{{trait._id}}'>
            <div class='bioclass-trait-row'>
              <div class='bioclass-trait-main'>
                <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Aspect.TraitName'}}</label>
                <span class='bioclass-trait-name-row'>
                  <input type='text' class='bioclass-trait-name' value='{{trait.name}}' disabled />
                </span>
              </div>
              <div class='bioclass-trait-controls'>
                <button type='button' data-action='editTraitItem' data-item-id='{{trait._id}}'>
                  <i class='fas fa-edit'></i>
                </button>
                <button type='button' data-action='deleteTraitItem' data-item-id='{{trait._id}}'>
                  <i class='fas fa-trash'></i>
                </button>
              </div>
            </div>
            <div class="trait-description">{{{trait.enrichedDescription}}}</div>
          </fieldset>
        {{/each}}
      </div>
    {{else}}
      <p>{{localize 'SYNTHICIDE.Actor.Aspect.NoTraits'}}</p>
    {{/if}}

  {{else}}
    <p>{{localize 'SYNTHICIDE.Actor.Aspect.NoneAssigned'}}</p>
    {{#if @root.editable}}
      <a class='item-control item-create' data-action='createDoc' data-document-class='Item' data-type='aspect'>
        <i class='fas fa-plus'></i>
        {{localize 'SYNTHICIDE.Actor.Aspect.Create'}}
      </a>
    {{/if}}
  {{/if}}
</section>
