{{! Sheet Header }}
<header class='sheet-header'>
  <img
    class='profile-img'
    src='{{actor.img}}'
    data-edit='img'
    data-action='editImage'
    data-tooltip='{{actor.name}}'
    height='100'
    width='100'
  />
  <div class='header-fields'>
    <!-- restructure to use CSS grid for neat alignment -->
    <div class="header-info-grid">
      <!-- row 1 -->
      <div class="header-info-name-block">
        <div class="header-info-label">{{localize 'SYNTHICIDE.Actor.Header.CharacterName'}}</div>
        <div class="header-info-value header-info-name">
          <input
            name="name"
            type="text"
            value="{{actor.name}}"
            placeholder="{{localize 'SYNTHICIDE.Actor.Header.CharacterName'}}"
            class="header-info-input"
          />
        </div>
      </div>
      <div class="header-info-level-block">
        <div class="header-info-label header-info-label-level">{{localize 'SYNTHICIDE.Actor.Header.Level'}}</div>
        <div class="header-info-value header-info-level">
          <input
            id="system.level.value"
            type="number"
            name="system.level.value"
            value="{{system.level.value}}"
            class="header-info-level-input"
            min="1"
          />
        </div>
      </div>

      <!-- row 2 -->
      <div class="header-info-bioclass-block">
        <div class="header-info-label">{{localize 'SYNTHICIDE.Actor.Header.Bioclass'}}</div>
        <div class="header-info-value bioclass-value">
          <input
            id="bioclass.name"
            type="text"
            name="bioclass.name"
            value="{{#if bioclass}}{{bioclass.name}}{{else}}—{{/if}}"
            disabled
          />
          
        </div>
      </div>
      <div class="header-info-motivation-block">
        <div class="header-info-label">{{localize 'SYNTHICIDE.Actor.Motivation.label'}}</div>
        <div class="header-info-value header-info-motivation">
          <select name="system.motivation" class="header-info-motivation-select" data-tooltip="{{localize (lookup @root.config.motivationBehaviors system.motivation)}}">
            {{selectOptions @root.config.motivationOptions selected=system.motivation localize=true}}
          </select>
        </div>
      </div>
      <div class="header-info-lurans-block">
        <div class="header-info-label header-info-label-lurans">{{localize 'SYNTHICIDE.Actor.Header.Lurans'}}</div>
        <div class="header-info-value header-info-lurans">
          <input
            id="system.lurans"
            type="number"
            name="system.lurnas"
            value="{{system.lurans}}"
            class="header-info-lurans-input"
            min="1"
          />
        </div>
      </div>
    </div>
  </div>
  {{! The grid classes are defined in scss/global/_grid.scss. To use,
      use both the "grid" and "grid-Ncol" class where "N" can be any number
      from 1 to 12 and will create that number of columns.  }}
  <div class="synthicide header-resource-flex">
      {{! "flex-group-center" is also defined in the _grid.scss file
        and it will add a small amount of padding, a border, and will
        center all of its child elements content and text. }}
      <!-- Hit Points Resource -->
      <div class='resource flex-group-center header-resource'>
        <label for='system.hitPoints.value' class='resource-label'>
          {{localize 'SYNTHICIDE.Actor.base.FIELDS.hitPoints.value.label'}}
        </label>
        <div class='resource-content flexrow flex-center flex-between resource-pair'>
          <input
            type='number'
            name='system.hitPoints.value'
            value='{{system.hitPoints.value}}'
            data-dtype='Number'
            max='{{system.hitPoints.max}}'
            step='1'
          />
          <span> / </span>
          <input
            type='number'
            name='system.hitPoints.max'
            value='{{system.hitPoints.max}}'
            data-dtype='Number'
            disabled
          />
        </div>
        <div class='resource-track'>
          <div class=
            {{#if (gte hpPercent 0.5)}}
              'resource-track-fill resource-track-fill-green'
            {{else if (gte hpPercent 0.25)}}
              'resource-track-fill resource-track-fill-yellow'
            {{else}}
              'resource-track-fill resource-track-fill-red'
            {{/if}}
            style='width: calc({{hpPercent}} * 100%);'></div>
        </div>
      </div>
      <!-- Force Barrier Resource -->
      <div class='resource flex-group-center header-resource'>
        <label for='system.armorValues.forceBarrier.value' class='resource-label'>
          {{localize 'SYNTHICIDE.Actor.base.FIELDS.armorValues.forceBarrier.value.label'}}
        </label>
        <div class='resource-content flexrow flex-center flex-between resource-pair'>
          <input
            type='number'
            name='system.armorValues.forceBarrier.value'
            value='{{system.armorValues.forceBarrier.value}}'
            data-dtype='Number'
          />
          <span> / </span>
          <input
            type='number'
            name='system.armorValues.forceBarrier.max'
            value='{{system.armorValues.forceBarrier.max}}'
            data-dtype='Number'
          />
        </div>
      </div>

      {{#if (eq actor.type 'npc')}}

      {{/if}}
      <!-- Cynicism Resource -->
      <div class='resource flex-group-center header-resource'>
        <label class='resource-label'>
          {{localize 'SYNTHICIDE.Actor.base.FIELDS.cynicism.label'}}
        </label>
        <div class='resource-content flexrow flex-center flex-between resource-counter'>
          <div class='resource-stepper' data-counter-key='cynicism'>
            {{#if @root.editable}}
              <button
                type='button'
                class='resource-step-btn'
                data-action='decreaseCounter'
                data-counter-key='cynicism'
                aria-label='Decrease cynicism'
              >-</button>
            {{/if}}
            <input
              type='number'
              name='system.cynicism'
              value='{{system.cynicism}}'
              data-dtype='Number'
              min='0'
              max='10'
              step='1'
            />
            {{#if @root.editable}}
              <button
                type='button'
                class='resource-step-btn'
                data-action='increaseCounter'
                data-counter-key='cynicism'
                aria-label='Increase cynicism'
              >+</button>
            {{/if}}
          </div>
        </div>
        <div class='resource-track resource-track-cynicism'>
          <div class='resource-track-fill' style='width: calc(({{system.cynicism}} / 10) * 100%);'></div>
        </div>
      </div>
      <!-- Resolve Resource -->
      <div class='resource flex-group-center header-resource'>
        <label class='resource-label'>
          {{localize 'SYNTHICIDE.Actor.base.FIELDS.resolve.label'}}
        </label>
        <div class='resource-content flexrow flex-center flex-between resource-counter'>
          <div class='resource-stepper' data-counter-key='resolve'>
            {{#if @root.editable}}
              <button
                type='button'
                class='resource-step-btn'
                data-action='decreaseCounter'
                data-counter-key='resolve'
                aria-label='Decrease resolve'
              >-</button>
            {{/if}}
            <input
              type='number'
              name='system.resolve'
              value='{{system.resolve}}'
              data-dtype='Number'
              min='0'
              max='5'
              step='1'
            />
            {{#if @root.editable}}
              <button
                type='button'
                class='resource-step-btn'
                data-action='increaseCounter'
                data-counter-key='resolve'
                aria-label='Increase resolve'
              >+</button>
            {{/if}}
          </div>
        </div>
        <div class='resource-track resource-track-resolve'>
          <div class='resource-track-fill' style='width: calc(({{system.resolve}} / 5) * 100%);'></div>
        </div>
      </div>
        <!-- Food Days Resource -->
        <div class='resource flex-group-center header-resource'>
          <label class='resource-label'>
            {{#if (lt system.foodDays.value 0)}}
            <span class="text-warning">{{localize 'SYNTHICIDE.Actor.base.FIELDS.foodDays.without'}}</span>
            {{else}}
            {{localize 'SYNTHICIDE.Actor.base.FIELDS.foodDays.label'}}
            {{/if}}
          </label>
          <div class='resource-content flexrow flex-center flex-between resource-counter'>
            <div class='resource-stepper' data-counter-key='foodDays'>
              {{#if @root.editable}}
                <button
                  type='button'
                  class='resource-step-btn'
                  data-action='decreaseCounter'
                  data-counter-key='foodDays'
                  aria-label='Decrease food days'
                >-</button>
              {{/if}}
              <input
                type='number'
                name='system.foodDays.value'
                value='{{system.foodDays.value}}'
                data-dtype='Number'
                min='{{system.foodDays.min}}'
                step='1'
              />
              {{#if @root.editable}}
                <button
                  type='button'
                  class='resource-step-btn'
                  data-action='increaseCounter'
                  data-counter-key='foodDays'
                  aria-label='Increase food days'
                >+</button>
              {{/if}}
            </div>
          </div>
        </div>
    </div>
</header>