{{! Traits Tab – leveled traits section (replaces former spells implementation) }}
<section
  class='tab traits scrollable {{tab.cssClass}}'
  data-group='primary'
  data-tab='traits'
>
  <ol class='items-list'>
    {{#each traitsByLevelOrdered as |entry|}}
      <li class='item flexrow items-header'>
        <div class='item-name'>
          {{localize 'SYNTHICIDE.Item.Trait.TraitLVL' level=entry.level}}
        </div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a
              class='item-control item-create'
              data-tooltip='{{localize "DOCUMENT.Create" type='Trait'}}'
              data-action='createDoc'
              data-document-class='Item'
              data-type='trait'
              data-system.level='{{entry.level}}'
              data-system.trait-type='generalTalent'
            >
              <i class='fas fa-plus'></i>
              {{localize 'SYNTHICIDE.Item.Trait.AddLVL' level=entry.level}}
            </a>
          {{/if}}
        </div>
      </li>
      {{#each entry.traits as |item id|}}
        <li
          class='item flexrow draggable'
          data-item-id='{{item._id}}'
          data-document-class='Item'
        >
          <div class='item-name flexrow'>
            <div class='item-image'>
              <a class='rollable' data-roll-type='item' data-action='roll'>
                <img
                  src='{{item.img}}'
                  data-tooltip='{{item.name}}'
                />
              </a>
            </div>
            <div class='item-label'>{{item.name}}</div>
          </div>
          <div class='item-controls'>
            <a
              class='item-control item-edit'
              data-tooltip='{{localize "DOCUMENT.Update" type='Trait'}}'
              data-action='viewDoc'
            >
              <i class='fas fa-edit'></i>
            </a>
            {{#if @root.editable}}
              <a
                class='item-control item-delete'
                data-tooltip='{{localize "DOCUMENT.Delete" type='Trait'}}'
                data-action='deleteDoc'
              >
                <i class='fas fa-trash'></i>
              </a>
            {{/if}}
          </div>
        </li>
      {{/each}}
    {{/each}}
  </ol>

</section>
