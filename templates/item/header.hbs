<header class='sheet-header'>
  <img
    class='profile-img'
    src='{{item.img}}'
    data-edit='img'
    data-action='onEditImage'
    data-tooltip='{{item.name}}'
  />
  <div class='header-fields'>
    <div class='document-name'>
      <input name='name' type='text' value='{{item.name}}' placeholder='Name' />
    </div>
    {{#if (eq item.type 'bioclass')}}
      <div class='resource'>
        <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Bioclass.Type'}}</label>
        <select name='system.bioclassType'>
          <option value='skinbag' {{#if (eq system.bioclassType 'skinbag')}}selected{{/if}}>{{localize 'SYNTHICIDE.Item.Bioclass.Skinbag'}}</option>
          <option value='scraphead' {{#if (eq system.bioclassType 'scraphead')}}selected{{/if}}>{{localize 'SYNTHICIDE.Item.Bioclass.Scraphead'}}</option>
          <option value='hardshell' {{#if (eq system.bioclassType 'hardshell')}}selected{{/if}}>{{localize 'SYNTHICIDE.Item.Bioclass.Hardshell'}}</option>
          <option value='rigfiend' {{#if (eq system.bioclassType 'rigfiend')}}selected{{/if}}>{{localize 'SYNTHICIDE.Item.Bioclass.Rigfiend'}}</option>
        </select>
      </div>
    {{/if}}
    {{! You may prefer to have a separate header file instead of this if statement}}
    {{#if (eq item.type 'gear')}}
      <div class='grid grid-2col'>
        <div class='resource'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Gear.FIELDS.quantity.label'}}</label>
          <input
            type='text'
            name='system.quantity'
            value='{{system.quantity}}'
            data-dtype='Number'
          />
        </div>
        <div class='resource'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Gear.FIELDS.weight.label'}}</label>
          <input
            type='text'
            name='system.weight'
            value='{{system.weight}}'
            data-dtype='Number'
          />
        </div>
      </div>
    {{/if}}
  </div>
</header>