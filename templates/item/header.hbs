<header class='sheet-header'>
  <img
    class='profile-img'
    src='{{item.img}}'
    data-edit='img'
    data-action='editImage'
    data-tooltip='{{item.name}}'
  />
  <div class='header-fields'>
    <div class='document-name'>
      <input name='name' type='text' value='{{item.name}}' placeholder='Name' />
    </div>
    {{! You may prefer to have a separate header file instead of this if statement}}
    {{#if isGear}}
      <div class='grid grid-4col'>
        <div class='resource'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Gear.FIELDS.quantity.label'}}</label>
          <input
            type='text'
            name='system.quantity'
            value='{{system.quantity}}'
            data-dtype='Number'
          />
        </div>
        <div class='resource'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Gear.FIELDS.weight.label'}}</label>
          <input
            type='text'
            name='system.weight'
            value='{{system.weight}}'
            data-dtype='Number'
          />
        </div>

        <div class='resource'>
          <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Gear.FIELDS.price.label'}}(§)</label>
          <input
            type='text'
            name='system.price'
            value='{{system.price}}'
            data-dtype='Number'
          />
        </div>
      
        <div class="item-nonstackable">
          <span class="resource-label">{{localize "SYNTHICIDE.Item.Gear.FIELDS.equipped.label"}}</span>
          <input type="checkbox" class="checkbox" name="system.equipped" {{checked system.equipped}} data-dtype="Boolean" />
        </div>
      </div>
    {{/if}}
  </div>
</header>