<div class='trait-top-fields'>
  <div class='resource resource-pair'>
    <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Cargo.FIELDS.Quantity'}}</label>
    <input
      type='number'
      name='system.quantity'
      value='{{system.quantity}}'
      min='1'
    />
  </div>
  <div class='resource resource-pair'>
    <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Cargo.FIELDS.UnitPrice'}}</label>
    <input
      type='number'
      name='system.unitPrice'
      value='{{system.unitPrice}}'
      min='0'
    />
  </div>
</div>