<div class="shield-group">
  <fieldset class="shield">
    <legend>{{localize 'SYNTHICIDE.Item.Shield.FIELDS.Protection'}}</legend>
    <div class='trait-top-fields'>
      <div class='resource resource-pair'>
        <label class='resource-label'>{{localize 'SYNTHICIDE.Item.Shield.FIELDS.adBonus'}}</label>
        <input
          type='number'
          name='system.adBonus'
          value='{{system.adBonus}}'
        />
      </div>
    </div>
  </fieldset>

  <fieldset class="shield">
    <legend>{{localize 'SYNTHICIDE.Item.Shield.FIELDS.Modifications'}}</legend>
    <div class='resource resource-pair'>
      <multi-select class="select shield-modifications" name="system.modifications" multiple>
        {{selectOptions shieldModificationsOptions selected=system.modifications localize=true}}
      </multi-select>
    </div>
  </fieldset>
</div>