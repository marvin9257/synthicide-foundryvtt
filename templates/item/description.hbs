{{! Description Tab }}
<section
  class='tab {{tab.cssClass}}'
  data-group='primary'
  data-tab='description'
>
  {{! Editors must receive enriched text data from getData to properly handle rolls, UUID links, etc. }}
  {{#if editable}}
    <div class='description-header'>{{localize 'SYNTHICIDE.Item.Tabs.Description'}}</div>
    <div class='trait-description-editor'>
      <prose-mirror name="system.description" data-document-uuid="{{item.uuid}}" value="{{system.description}}" collaborate="true" toggled="true">
        {{{enrichedDescription}}}
      </prose-mirror>
    </div>
  {{else}} {{{enrichedDescription}}}
  {{/if}}

</section>