<li data-index="{{index}}">
  <div class="key">
    <select name="{{change.keyPath}}">
      <option value=""></option>
      {{selectOptions changeSelectOptions selected=change.key localize=true}}
    </select>
  </div>
  <div class="type">
    <select name="{{change.typePath}}">
      {{#each changeTypes}}
        <option value="{{@key}}" {{#if (eq @key ../change.type)}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
  </div>
  <div class="value">
    <input type="text" name="{{change.valuePath}}" value='{{change.value}}'>
  </div>
  <input type="hidden" name="{{change.phasePath}}" value="initial">
  <div class="priority">
    <input type="number" name="{{change.priorityPath}}" placeholder="{{defaultPriority}}">
  </div>
  <div class="controls">
    <button type="button" class="inline-control icon fa-solid fa-trash" data-action="deleteChange"></button>
  </div>
</li>
