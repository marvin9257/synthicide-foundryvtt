{{! Locker Tab }}
<section class='tab locker scrollable {{tab.cssClass}}' data-group='primary' data-tab='locker'>
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>{{localize 'Name'}}</div>
      <div class='item-prop item-prop--type'>{{localize 'Type'}}</div>
      <div class='item-prop item-prop--quantity'>{{localize 'SYNTHICIDE.Item.Cargo.FIELDS.Quantity'}}</div>
      <div class='item-prop item-prop--unit-price'>{{localize 'SYNTHICIDE.Item.Cargo.FIELDS.UnitPrice'}}</div>
      <div class='item-controls item-controls--locker'>
        {{#if @root.editable}}
          <a
            class='item-control item-create'
            data-tooltip='{{localize "DOCUMENT.Create" type='Item'}}'
            data-action='createDoc'
            data-document-class='Item'
            data-type='gear'
          >
            <i class='fas fa-plus'></i>
            {{localize 'DOCUMENT.New' type='item'}}
          </a>
        {{/if}}
      </div>
    </li>
    {{#each locker as |item id|}}
      <li
        class='item flexrow draggable'
        data-item-id='{{item._id}}'
        data-document-class='Item'
      >
        <div class='item-name'>
          <div class='item-image'>
            <img src='{{item.img}}'/>
          </div>
          <div class='item-label'>{{item.name}}</div>
        </div>
        <div class='item-prop item-prop--type'>
          {{#if (lookup @root.itemTypeIcons item.type)}}
            <i
              class='locker-item-type-icon {{lookup @root.itemTypeIcons item.type}}'
              data-tooltip='{{localize (concat "TYPES.Item." item.type)}}'
              aria-label='{{localize (concat "TYPES.Item." item.type)}}'
            ></i>
          {{else}}
            <i
              class='locker-item-type-icon {{@root.itemTypeIcons.default}}'
              data-tooltip='{{localize (concat "TYPES.Item." item.type)}}'
              aria-label='{{localize (concat "TYPES.Item." item.type)}}'
            ></i>
          {{/if}}
        </div>
        <div class='item-prop item-prop--quantity'>
          {{#if item.system.quantity}}{{item.system.quantity}}{{else}}-{{/if}}
        </div>
        <div class='item-prop item-prop--unit-price'>
          {{#if item.system.price}}{{item.system.price}}{{else}}-{{/if}}
        </div>
        <div class='item-controls item-controls--locker'>
          {{#if @root.editable}}
            <a
              class='item-control item-edit'
              data-tooltip='{{localize "DOCUMENT.Update" type='Item'}}'
              data-action='viewDoc'
            >
              <i class='fas fa-edit'></i>
            </a>
          
            <a
              class='item-control item-delete'
              data-tooltip='{{localize "DOCUMENT.Delete" type='Item'}}'
              data-action='deleteDoc'
            >
              <i class='fas fa-trash'></i>
            </a>
          {{/if}}
        </div>
      </li>
    {{/each}}
  </ol>

</section>
