{{! Ship Weapons Tab }}
<section class='tab shipWeapons scrollable {{tab.cssClass}}' data-group='primary' data-tab='shipWeapons'>
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>{{localize 'Name'}}</div>
      <div class='item-prop item-prop--quantity'>{{localize 'SYNTHICIDE.Item.Cargo.FIELDS.Quantity'}}</div>
      <div class='item-prop item-prop--range'>{{localize 'SYNTHICIDE.Item.ShipWeapon.FIELDS.Range'}}</div>
      <div class='item-prop item-prop--is-missile' data-tooltip='{{localize "SYNTHICIDE.Item.ShipWeapon.FIELDS.IsMissile"}}'>
        <i class='fa-solid fa-rocket' aria-label='{{localize "SYNTHICIDE.Item.ShipWeapon.FIELDS.IsMissile"}}'></i>
      </div>
      <div class='item-prop item-prop--dmg-multiplier'>{{localize 'SYNTHICIDE.Item.ShipWeapon.FIELDS.DmgMultiplier'}}</div>
      <div class='item-prop item-prop--item-cost'>{{localize 'SYNTHICIDE.Item.ShipWeapon.FIELDS.ItemCost'}}</div>
      <div class='item-controls item-controls--ship-weapons'>
        {{#if @root.editable}}
          <a
            class='item-control item-create'
            data-tooltip='{{localize "DOCUMENT.Create" type='Item'}}'
            data-action='createDoc'
            data-document-class='Item'
            data-type='shipWeapon'
          >
            <i class='fas fa-plus'></i>
            {{localize 'DOCUMENT.New' type='item'}}
          </a>
        {{/if}}
      </div>
    </li>
    {{#each shipWeapons as |item id|}}
      <li
        class='item flexrow draggable'
        data-item-id='{{item._id}}'
        data-document-class='Item'
      >
        <div class='item-name'>
          <div class='item-image'>
            <a
              class='rollable'
              data-action='roll'
              data-roll-type='shipWeaponDamage'
              data-tooltip='{{localize "SYNTHICIDE.Roll.Tooltip.RollShipWeaponDamage" item=item.name}}'
            >
              <img
                src='{{item.img}}'
                data-tooltip='{{localize "SYNTHICIDE.Roll.Tooltip.RollShipWeaponDamage" item=item.name}}'
              />
            </a>
          </div>
          <div class='item-label'>{{item.name}}</div>
        </div>
        <div class='item-prop item-prop--quantity'>
          {{item.system.quantity}}
        </div>
        <div class='item-prop item-prop--range'>
          {{localize (lookup @root.shipWeaponRanges item.system.range)}}
        </div>
        <div class='item-prop item-prop--is-missile'>
          {{#if item.system.isMissile}}
            <i class='fa-regular fa-square-check' aria-label='{{localize "SYNTHICIDE.Item.ShipWeapon.FIELDS.IsMissile"}}'></i>
          {{else}}
            <i class='fa-regular fa-square' aria-label='{{localize "SYNTHICIDE.Item.ShipWeapon.FIELDS.IsMissile"}}'></i>
          {{/if}}
        </div>
        <div class='item-prop item-prop--dmg-multiplier'>
          x{{item.system.dmgMultiplier}}
        </div>
        <div class='item-prop item-prop--item-cost'>
          {{item.system.price}}
        </div>
        <div class='item-controls item-controls--ship-weapons'>
          {{#if @root.editable}}
            <a
              class='item-control item-roll-ship-weapon'
              data-tooltip='{{localize "SYNTHICIDE.Roll.Tooltip.RollShipWeaponDamage" item=item.name}}'
              data-action='roll'
              data-roll-type='shipWeaponDamage'
            >
              <i class='fa-solid fa-crosshairs'></i>
            </a>
            <a
              class='item-control item-edit'
              data-tooltip='{{localize "DOCUMENT.Update" type='Item'}}'
              data-action='viewDoc'
            >
              <i class='fas fa-edit'></i>
            </a>
            <a
              class='item-control item-delete'
              data-tooltip='{{localize "DOCUMENT.Delete" type='Item'}}'
              data-action='deleteDoc'
            >
              <i class='fas fa-trash'></i>
            </a>
          {{/if}}
        </div>
      </li>
    {{/each}}
  </ol>
</section>
