{{! Cargo Tab }}
<section class='tab cargo scrollable {{tab.cssClass}}' data-group='primary' data-tab='cargo'>
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>{{localize 'Name'}}</div>
      <div class='item-prop item-prop--quantity'>{{localize 'SYNTHICIDE.Item.Cargo.FIELDS.Quantity'}}</div>
      <div class='item-prop item-prop--unit-price'>{{localize 'SYNTHICIDE.Item.Cargo.FIELDS.UnitPrice'}}</div>
      <div class='item-controls item-controls--cargo'>
        {{#if @root.editable}}
          <a
            class='item-control item-create'
            data-tooltip='{{localize "DOCUMENT.Create" type='Item'}}'
            data-action='createDoc'
            data-document-class='Item'
            data-type='cargo'
          >
            <i class='fas fa-plus'></i>
            {{localize 'DOCUMENT.New' type='item'}}
          </a>
        {{/if}}
      </div>
    </li>
    {{#each cargo as |item id|}}
      <li
        class='item flexrow draggable'
        data-item-id='{{item._id}}'
        data-document-class='Item'
      >
        <div class='item-name'>
          <div class='item-image'>
            <img
              src='{{item.img}}'
              data-tooltip='{{localize "SYNTHICIDE.Roll.Tooltip.RollWithItem" item=item.name}}'
            />
          </div>
          <div class='item-label'>{{item.name}}</div>
        </div>
        <div class='item-prop item-prop--quantity'>
          {{item.system.quantity}}
        </div>
        <div class='item-prop item-prop--unit-price'>
          {{item.system.unitPrice}}
        </div>
        <div class='item-controls item-controls--cargo'>
          {{#if @root.editable}}
            <a
              class='item-control item-edit'
              data-tooltip='{{localize "DOCUMENT.Update" type='Gear'}}'
              data-action='viewDoc'
            >
              <i class='fas fa-edit'></i>
            </a>
          
            <a
              class='item-control item-delete'
              data-tooltip='{{localize "DOCUMENT.Delete" type='Gear'}}'
              data-action='deleteDoc'
            >
              <i class='fas fa-trash'></i>
            </a>
          {{/if}}
        </div>
      </li>
    {{/each}}
  </ol>

</section>